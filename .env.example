# Single place for ClawCodex provider credentials (repo root, same folder as README.md).
#
# Easiest on Windows: double-click START-CLAW.bat. It asks you to choose
# OpenRouter, Cerebras, Z.ai, DeepSeek, or Kimi, validates your key, then launches Claw.
#
# Manual path:
#   1. Copy this file to `.env` in the repo root.
#   2. Set CLAW_PROVIDER and the matching API key once.
#   3. Run:  START-CLAW.bat
#
# `.env` is gitignored so your keys are not pushed by mistake.
#
# OpenRouter:
#   CLAW_PROVIDER=openrouter
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_API_KEY=YOUR_OPENROUTER_KEY_HERE
#
# Cerebras:
#   CLAW_PROVIDER=cerebras
#   CEREBRAS_API_KEY=YOUR_CEREBRAS_KEY_HERE
#   CLAW_CEREBRAS_MODEL=gpt-oss-120b
#   (START-CLAW also mirrors CEREBRAS_API_KEY into OPENAI_* for the claw CLI.)
#
# Z.ai:
#   CLAW_PROVIDER=zai
#   ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   ZAI_API_KEY=YOUR_ZAI_KEY_HERE
#   CLAW_ZAI_MODEL=glm-5.2
#   (START-CLAW filters picker results to glm-4*/glm-5* and mirrors ZAI_API_KEY into OPENAI_*.)
#
# DeepSeek:
#   CLAW_PROVIDER=deepseek
#   DEEPSEEK_BASE_URL=https://api.deepseek.com
#   DEEPSEEK_API_KEY=YOUR_DEEPSEEK_KEY_HERE
#   CLAW_DEEPSEEK_MODEL=deepseek-v4-flash
#   (START-CLAW mirrors DEEPSEEK_API_KEY into OPENAI_* for the claw CLI.)
#
# Kimi:
#   CLAW_PROVIDER=kimi
#   KIMI_BASE_URL=https://api.moonshot.ai/v1
#   KIMI_API_KEY=YOUR_KIMI_KEY_HERE
#   MOONSHOT_API_KEY=YOUR_MOONSHOT_KEY_HERE
#   CLAW_KIMI_MODEL=kimi-k2.7-code
#   (START-CLAW mirrors KIMI_API_KEY into OPENAI_* for the claw CLI.)
#
# Verify keys:
#   powershell -File .\validate-openrouter.ps1
#   powershell -File .\validate-cerebras.ps1
#   powershell -File .\validate-zai.ps1
#   powershell -File .\validate-deepseek.ps1
#   powershell -File .\validate-kimi.ps1

CLAW_PROVIDER=openrouter
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=YOUR_OPENROUTER_KEY_HERE
CEREBRAS_API_KEY=YOUR_CEREBRAS_KEY_HERE
CLAW_CEREBRAS_MODEL=gpt-oss-120b
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZAI_API_KEY=YOUR_ZAI_KEY_HERE
CLAW_ZAI_MODEL=glm-5.2
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_KEY_HERE
CLAW_DEEPSEEK_MODEL=deepseek-v4-flash
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_API_KEY=YOUR_KIMI_KEY_HERE
MOONSHOT_API_KEY=YOUR_MOONSHOT_KEY_HERE
CLAW_KIMI_MODEL=kimi-k2.7-code
