# Copy this file to .env in the repo root or beside claw.exe and fill in one provider.

# Anthropic direct API
ANTHROPIC_API_KEY=YOUR_API_KEY_HERE

# Anthropic-compatible proxy or OAuth bearer token
# ANTHROPIC_BASE_URL=https://your-proxy.example
# ANTHROPIC_AUTH_TOKEN=anthropic-oauth-or-proxy-bearer-token

# OpenRouter / OpenAI-compatible providers
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=YOUR_API_KEY_HERE

# xAI
# XAI_API_KEY=YOUR_API_KEY_HERE

# DashScope / Qwen
# DASHSCOPE_API_KEY=YOUR_API_KEY_HERE
