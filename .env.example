# One-time setup (recommended — single place for your key):
#   1. Copy this file to `.env` in the same folder as README.md (repo root).
#   2. Replace YOUR_OPENROUTER_KEY_HERE with your real OpenRouter API key once.
#   3. Run:  .\run-claw.ps1 doctor
#
# The `claw` binary reads `.env` from the repo root when you use run-claw.ps1 / run-claw.bat.
# `.env` is gitignored so your key is not pushed by mistake.

OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=YOUR_OPENROUTER_KEY_HERE
